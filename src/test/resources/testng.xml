<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  HYPER-PARALLEL CHROME EXECUTION
  - Browser: Google Chrome ONLY
  - parallel="methods"           -> each @Test method runs in its own thread
  - thread-count="10"            -> caps max concurrent Chrome instances
  - data-provider-thread-count="4" -> caps parallel DataProvider invocations

  Login = 5 (1 positive + 4 negative) | Home = 12 (6 positive + 6 negative) | Home Property Search = 5 (3 positive + 2 negative, sequential)
  Properties = 6 (3 positive + 3 negative)
  Profile = 5 (2 positive + 3 negative) | Contact Us = 6 (3 positive + 3 negative) | FAQ = 7 (5 positive + 2 negative)
  Focused parallel suite for these 3 modules: testng-profile-contact-faq-parallel.xml (mvn test -Pprofile-contact-faq)
  Draft Lifecycle = 8 (3 chained + 5 country variants) | Published Lifecycle = 4 chained + 4 status + 1 negative
-->
<suite name="Cora Suite"
       parallel="methods"
       thread-count="10"
       data-provider-thread-count="4"
       verbose="1">

    <listeners>
        <listener class-name="com.cora.listeners.TestListener"/>
    </listeners>

    <test name="Cora Tests - Chrome Parallel">
        <classes>
            <class name="com.cora.tests.LoginTest"/>
            <class name="com.cora.tests.HomeTest"/>
            <class name="com.cora.tests.PropertiesTest"/>
            <class name="com.cora.tests.ProfileTest"/>
            <class name="com.cora.tests.ContactUsTest"/>
            <class name="com.cora.tests.FaqTest"/>
        </classes>
    </test>

    <test name="Home Property Search" parallel="false" preserve-order="true">
        <classes>
            <class name="com.cora.tests.HomePropertySearchTest"/>
        </classes>
    </test>

    <test name="Properties Draft Lifecycle" parallel="false" preserve-order="true">
        <classes>
            <class name="com.cora.tests.PropertiesDraftLifecycleTest"/>
        </classes>
    </test>

    <test name="Properties Published Lifecycle" parallel="false" preserve-order="true">
        <classes>
            <class name="com.cora.tests.PropertiesPublishedLifecycleTest"/>
        </classes>
    </test>

    <test name="Properties Negative Countries + Status" parallel="false" preserve-order="true">
        <classes>
            <class name="com.cora.tests.PropertiesNegativeCountriesAndStatusTest"/>
        </classes>
    </test>

</suite>
